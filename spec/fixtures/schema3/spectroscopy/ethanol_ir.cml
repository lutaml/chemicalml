  <spectrum id="s1" format="ir" convention="convention:spectroscopy"
            title="ethanol IR spectrum">
    <peakList>
      <peak id="p1" xValue="3650" xUnits="cm-1" yValue="0.85" yMultiplicity="s"/>
      <peak id="p2" xValue="2970" xUnits="cm-1" yValue="0.72" yMultiplicity="br"/>
      <peak id="p3" xValue="1050" xUnits="cm-1" yValue="0.91" yMultiplicity="s"/>
    </peakList>
  </spectrum>
</cml>
