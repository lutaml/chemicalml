<?xml version="1.0" encoding="UTF-8"?>
<cml xmlns="http://www.xml-cml.org/schema"
     xmlns:convention="http://www.xml-cml.org/convention/"
     convention="convention:molecular">
  <molecule id="parent" title="ethanol solution">
    <molecule id="etoh" count="1">
      <name>ethanol</name>
      <formula concise="C 2 H 6 O 1"/>
    </molecule>
    <molecule id="water" count="3">
      <name>water</name>
      <formula concise="H 2 O 1"/>
    </molecule>
  </molecule>
</cml>
